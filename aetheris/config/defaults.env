# AETHERIS Gridline Runtime — Configuration

## Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fsh_command
POSTGRES_USER=postgres
# POSTGRES_PASSWORD= (set via .env, never committed)

## API Keys
# OPENROUTER_API_KEY= (set via .env, never committed)
# ANTHROPIC_API_KEY= (set via .env, never committed)

## Hermes Agent
HERMES_BIN=hermes-agent
HERMES_MAX_TURNS=5
HERMES_TIMEOUT=300

## n8n
N8N_WEBHOOK_URL=http://localhost:5678/webhook/fsh-status-callback

## Approval
APPROVAL_TOKEN_EXPIRY_HOURS=24
APPROVAL_BASE_URL=http://localhost:8000

## Cron Schedule
CRON_INVESTRA_IMPORT=0 6 * * *
CRON_SCORE_RECALC=0 7 * * *
CRON_DISTRESS_DETECT=0 8 * * *
CRON_DAILY_REPORT=0 18 * * *
CRON_COMPLIANCE_REVIEW=0 10 * * 1
