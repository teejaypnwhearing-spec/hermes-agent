{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aetheris.fermier.io/schemas/lead_batch.json",
  "title": "Lead Batch",
  "description": "Batch of leads from an Investra export or other data source for the Gridline pipeline.",
  "type": "object",
  "required": ["batch_id", "source", "records"],
  "properties": {
    "batch_id": {
      "type": "string",
      "description": "Unique batch identifier"
    },
    "source": {
      "type": "string",
      "enum": ["investra", "manual", "api", "csv_upload"],
      "description": "Where the leads came from"
    },
    "imported_at": {
      "type": "string",
      "format": "date-time"
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["property_address"],
        "properties": {
          "property_address": {
            "type": "string",
            "description": "Full property address"
          },
          "owner_name": {
            "type": ["string", "null"],
            "description": "Property owner name (PII)"
          },
          "equity_pct": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Owner equity percentage"
          },
          "motivation_score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10,
            "description": "Seller motivation score (0-10)"
          },
          "distress_flags": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "tax_delinquent", "absentee_owner", "pre_foreclosure",
                "recent_listing", "code_violation", "vacant",
                "inheritance", "divorce", "relocation", "bankruptcy"
              ]
            },
            "default": [],
            "description": "Distress signals detected"
          },
          "arv": {
            "type": ["number", "null"],
            "description": "After Repair Value estimate"
          },
          "repair_estimate": {
            "type": ["number", "null"],
            "description": "Estimated repair cost"
          },
          "source_id": {
            "type": ["string", "null"],
            "description": "ID from the source system"
          }
        }
      },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
