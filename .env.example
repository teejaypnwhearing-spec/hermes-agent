# ═══════════════════════════════════════════════════════════════════════
# FSH Command Center — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in values before running docker-compose.
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════

# ── Postgres ───────────────────────────────────────────────────────────
POSTGRES_PASSWORD=fsh_dev_password

# ── n8n (Approval Callbacks & Retry Queue) ────────────────────────────
N8N_HOST=localhost
N8N_USER=admin
N8N_PASSWORD=fsh_n8n_password

# ── AI Engine API Keys ────────────────────────────────────────────────
# At least one engine key is required for live task execution.
# Without keys, the orchestrator runs in stub/dry-run mode.
ANTHROPIC_API_KEY=
ABACUS_API_URL=https://apps.abacus.ai
ABACUS_API_KEY=
MANUS_API_URL=https://api.manus.ai
MANUS_API_KEY=
CLAUDE_MODEL=claude-opus-4-5

# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated origins allowed to access the API.
# Use "*" for development (default).
CORS_ORIGINS=*

# ── Optional: Database URL override ───────────────────────────────────
# If set, overrides the docker-compose default (postgres://...).
# When NOT set and no DATABASE_URL env var exists, the server
# auto-falls back to SQLite with seeded sample data.
# DATABASE_URL=postgresql://fsh_user:password@localhost:5432/fsh_command_center
